<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Chat</title>
    <link rel="stylesheet" href="/css/chat.css">
</head>

<body>
    <div class="main">
        <div class="chat-history" id="chatHistory"></div>
        <div class="send-form">
            <form action="" id="sendForm">
                <input type="text" id="message">
                <button type="submit">Send</button>
            </form>
        </div>
    </div>
    <script>
        const nickname = '<%= nickname %>';
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('sendForm').addEventListener('submit', (e) => {
                e.preventDefault();
                sendMessage();
            })
            poll();
        });

        function getMessageClass(hisMessage) {
            if (hisMessage.nickname === nickname) {
                return 'myself-msg';
            }
            if(hisMessage.nickname === 'System') {
                return 'system-msg';
            }
            return '';
        }

        async function poll() {
            // 1. fetch data from server
            const response = await fetch('/poll');
            const data = await response.json();
            const chatHistoryElem = document.getElementById('chatHistory')
            const bottomGap = chatHistoryElem.scrollHeight - chatHistoryElem.scrollTop - chatHistoryElem.clientHeight;
            // 2. populate data into chat history section
            document.getElementById('chatHistory').innerHTML = data
            .map(his => `<p class="${getMessageClass(his)}">${his.nickname}:  ${his.message} </p>`)
            .join('');
            if (bottomGap < 5) {
            chatHistoryElem.scrollTop = chatHistoryElem.scrollHeight;
            }
            // 3. set the next run
            setTimeout(poll, 1000);
        }
ç
        function sendMessage() {
            const message = document.getElementById('message').value;
            fetch('/send ', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    messageContent: message,
                   nickname: nickname
                })
                   
            });
            document.getElementById('message').value = '';
        }
    </script>
</body>

</html>